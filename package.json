{
  "name": "playwright-test-ai-inspector",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright tests with AI-assisted inspection",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "setup": "npm install && npm install --prefix app && npm run playwright:install",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers npx playwright install chromium",
    "dev": "npm run dev --prefix app",
    "build": "npm run build --prefix app",
    "preview": "npm run preview --prefix app",
    "test": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test",
    "test:smoke": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --grep @smoke",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --grep @e2e --pass-with-no-tests",
    "test:ui": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --ui",
    "test:headed": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --headed",
    "report": "playwright show-report playwright-report",
    "trace": "playwright show-trace"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1"
  }
}
